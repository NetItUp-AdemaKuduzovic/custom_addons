<?xml version="1.0"?>
<odoo>
    <!--Stamping List View-->
    <record id="niu_stamping_list_view" model="ir.ui.view">
        <field name="name">niu.stamping.view.list</field>
        <field name="model">niu.stamping</field>
        <field name="arch" type="xml">
            <list>
                <field name="employee_id" widget="many2one_avatar_user"/>
                <field name="badge_id"/>
                <field name="stamping_direction"/>
                <field name="stamping_timestamp"/>
            </list>
        </field>
    </record>

    <!--Stamping Form View-->
    <record id="niu_stamping_form_view" model="ir.ui.view">
        <field name="name">niu.stamping.view.form</field>
        <field name="model">niu.stamping</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="badge_id"/>
                            <field name="stamping_timestamp"/>
                        </group>
                        <group>
                            <field name="employee_id" widget="many2one_avatar_user"/>
                            <field name="stamping_direction"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="niu_stamping_action" model="ir.actions.act_window">
        <field name="name">Stampings</field>
        <field name="res_model">niu.stamping</field>
        <field name="view_mode">list,form</field>
    </record>
    
</odoo>